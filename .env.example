# ---------------------------------------------------------------------------
# US Politicians Explorer — variáveis de ambiente
# Copie este arquivo para `.env` na raiz e preencha os valores reais.
#   cp .env.example .env
# O `.env` é injetado pelo docker-compose em cada serviço e nunca é commitado.
# ---------------------------------------------------------------------------

# OpenStates API v3 (https://open.pluralpolicy.com/accounts/profile/)
# Token obrigatório — enviado no header X-Api-Key. Sem ele o backend nem sobe.
OPENSTATES_API_KEY=xxxxx
OPENSTATES_BASE_URL=https://v3.openstates.org

# Postgres (container `db`)
POSTGRES_USER=politics
POSTGRES_PASSWORD=politics
POSTGRES_DB=politics
# Porta publicada no host (mude se já houver um Postgres local ocupando a 5432).
POSTGRES_HOST_PORT=5432
# `db:5432` é o hostname da rede docker — válido no runtime em container.
# Para rodar a CLI do Prisma NA MÁQUINA HOST (ex.: `prisma migrate dev`), use
# `localhost:5432` num `server/.env` próprio (a porta é exposta pelo docker-compose).
DATABASE_URL=postgresql://politics:politics@db:5432/politics?schema=public

# Backend
BACKEND_PORT=3000
CORS_ORIGIN=http://localhost:8080

# --- Sync ---
# A cota do tier free (~500 req/dia, ~1 req/s) é o recurso escasso: todo o
# desenho abaixo existe para não estourá-la.

# Estados sincronizados. VAZIO = TODOS os estados (lista vem de GET /jurisdictions),
# o que custa ~150 requisições, ~30% da cota diária. Preencha em dev.
# Ex.: SYNC_STATES=California,New York,Texas
SYNC_STATES=
# Resultados por página. 10 é o default da API; usamos 50. O client avisa se a
# API ecoar um valor menor — o custo de cota subiria ~5x em silêncio.
SYNC_PER_PAGE=50
# Delay entre requisições (ms). Tier free = 1 req/s; 1100 dá margem contra jitter.
SYNC_REQUEST_DELAY_MS=1100

# Sync automático diário. false => só sync manual via POST /api/sync.
SYNC_SCHEDULE_ENABLED=true
SYNC_CRON=0 3 * * *
SYNC_CRON_TIMEZONE=America/Sao_Paulo
# Sync no boot. false por default: cada `up` em dev gastaria um sync inteiro.
SYNC_ON_STARTUP=false

# Frontend (build-arg do Vite)
VITE_API_URL=http://localhost:3000/api
