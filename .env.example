# ---------------------------------------------------------------------------
# US Politicians Explorer — variáveis de ambiente
# Copie este arquivo para `.env` na raiz e preencha os valores reais.
#   cp .env.example .env
# O `.env` é injetado pelo docker-compose em cada serviço e nunca é commitado.
# ---------------------------------------------------------------------------

# OpenStates API v3 (https://open.pluralpolicy.com/accounts/profile/)
# Token obrigatório — enviado no header X-Api-Key. Sem ele o sync falha.
OPENSTATES_API_KEY=xxxxx

# Postgres (container `db`)
POSTGRES_USER=politics
POSTGRES_PASSWORD=politics
POSTGRES_DB=politics
DATABASE_URL=postgresql://politics:politics@db:5432/politics?schema=public

# Backend
BACKEND_PORT=3000
CORS_ORIGIN=http://localhost:8080
# Lista de estados sincronizados (respeita o rate limit — NÃO todos os 50)
SYNC_STATES=California,New York,Texas
# Agendamento do sync (node-cron) — ex.: diário às 03:00
SYNC_CRON=0 3 * * *
# Delay entre requisições à OpenStates (ms) para respeitar o rate limit
SYNC_REQUEST_DELAY_MS=400
# Dispara um sync no primeiro boot do backend
SYNC_ON_STARTUP=true

# Frontend (build-arg do Vite)
VITE_API_URL=http://localhost:3000/api
