// Repo PTBR: modelo `Politico`, tabela `politicos`, colunas em português.
// Todos os campos vindos da OpenStates são opcionais: a API omite `current_role`,
// `party` e afins para políticos sem cargo atual. Só `openstatesId`, `nome` e
// `estado` são garantidos.

generator client {
  provider     = "prisma-client" // Prisma 7: gerador novo (sem `-js`)
  output       = "../src/generated/prisma" // `output` é obrigatório no Prisma 7
  moduleFormat = "esm" // projeto server/ é ESM ("type": "module")
}

datasource db {
  provider = "postgresql"
  // Prisma 7: a connection string vive em `prisma.config.ts`, não mais aqui.
}

model Politico {
  id           String @id @default(cuid())
  openstatesId String @unique // id da OpenStates — chave do upsert (cache idempotente)

  nome         String
  primeiroNome String? // given_name — ordenação sem parsear `nome`
  sobrenome    String? // family_name

  cargo    String? // current_role.title
  camara   String? // current_role.org_classification: "upper" | "lower"
  distrito String? // current_role.district — string: há distritos não-numéricos ("At-Large")
  estado   String
  partido  String?

  foto  String?
  email String?

  genero      String?
  nascimento  DateTime? @db.Date // birth_date
  falecimento DateTime? @db.Date // death_date — sem isso, morto aparece como no cargo

  openstatesUrl String?
  contatos      Json? // array `offices`: endereço, telefone, fax
  raw           Json? // payload completo: permite backfill sem re-sync

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([estado])
  @@index([partido])
  @@map("politicos")
}
